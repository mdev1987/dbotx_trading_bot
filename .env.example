# ═══════════════════════════════════════════════════════════════════════════════
# DBotX Trade Bot — Example Environment
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  DBotX API — Connection                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘


DBOTX_API_KEY=your_dbotx_api_key
DBOTX_WS_URL=wss://api-data-v1.dbotx.com/data/ws/
DBOTX_BASE_URL=https://api-bot-v1.dbotx.com
DBOTX_SERVAPI_BASE_URL=https://servapi.dbotx.com

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Position Sizing & Limits                                        │
# └─────────────────────────────────────────────────────────────────────────────┘

POSITION_SIZE_SOL=0.10
MIN_POSITION_SOL=0.03
MAX_POSITION_SOL=0.10
MAX_RISK_PCT=10.0
SOL_PRICE_USD=150
MAX_POSITIONS=20
SIGNAL_QUEUE_SIZE=30
SIGNAL_QUEUE_TTL_SECS=600

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Position TTL                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

BASE_TTL_SECS=300
MIN_PROFIT_FOR_TTL_EXTENSION_PCT=8.0
MAX_TTL_SECS=3600

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Take-Profit / Stop-Loss                                         │
# └─────────────────────────────────────────────────────────────────────────────┘

PARTIAL_TP_ENABLED=true
PARTIAL_TP_TIERS=25@30,25@60,25@100
PAPER_BACKSTOP_TP_PERCENT=200
PAPER_STOP_LOSS_PERCENT=-15
PAPER_TRAILING_ACTIVATION_PERCENT=15
PAPER_TRAILING_STOP_PERCENT=8
PAPER_TRAILING_TP_PERCENT=12
PAPER_MAX_SLIPPAGE_EXIT_PERCENT=80

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Risk Controls                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

DAILY_LOSS_LIMIT_USD=0

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Data & Analytics                                                          │
# └─────────────────────────────────────────────────────────────────────────────┘

SQLITE_PATH=./data/paper_trading.sqlite
CLEAR_ANALYTICS_ON_START=true

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Bot Reporting                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_REPORT_INTERVAL_MINUTES=10

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Signal Listener                                                │
# └─────────────────────────────────────────────────────────────────────────────┘

TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_CHANNEL_USERNAME=AveSignalMonitor
TELEGRAM_CHANNEL_ID=your_telegram_channel_id

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Polling & Timing — Position Lifecycle                                     │
# └─────────────────────────────────────────────────────────────────────────────┘

PNL_TASK_POLL_MS=5000
TRADE_PAIR_POLL_MS=30000
ENTRY_PRICE_POLL_DELAY_MS=1000
MAX_ENTRY_PRICE_ATTEMPTS=10
PENDING_BUY_TTL_MS=60000
POSITION_EXPIRY_CHECK_MS=15000
ACCOUNT_POLL_INTERVAL_MS=60000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  WebSocket — Connection & Heartbeat                                        │
# └─────────────────────────────────────────────────────────────────────────────┘

WS_HEARTBEAT_INTERVAL_MS=30000
WS_DISCONNECT_LOG_THROTTLE_MS=30000
WS_RECONNECT_DELAY_MS=5000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Signal Deduplication                                                      │
# └─────────────────────────────────────────────────────────────────────────────┘

SIGNAL_CACHE_TTL_SECONDS=3600
SIGNAL_CLEANUP_INTERVAL_MS=5000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  HTTP Client — Retry & Timeout                                             │
# └─────────────────────────────────────────────────────────────────────────────┘

HTTP_MAX_RETRIES=4
HTTP_BASE_DELAY_MS=1000
HTTP_TIMEOUT_MS=30000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram Connection — MTProto Client                                      │
# └─────────────────────────────────────────────────────────────────────────────┘

TG_CONNECTION_RETRIES=5
TG_RETRY_DELAY_MS=5000
TG_AUTH_TIMEOUT_MS=300000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading Mode                                                        │
# └─────────────────────────────────────────────────────────────────────────────┘

LIVE_MODE=false
LIVE_ENABLED=true
LIVE_WALLET_ID=your_dbotx_wallet_id
LIVE_WALLET_ADDRESS=your_wallet_public_address
LIVE_RECOVERY_ON_START=true
LIVE_DB_PATH=./data/live_trading.sqlite

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — Jito / Anti-MEV                                           │
# └─────────────────────────────────────────────────────────────────────────────┘

LIVE_JITO_ENABLED=true
LIVE_JITO_TIP=0.0001
LIVE_CUSTOM_FEE_AND_TIP=false
LIVE_PRIORITY_FEE=
LIVE_MAX_SLIPPAGE=0.1
LIVE_CONCURRENT_NODES=2
LIVE_RETRIES=1

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — Dev Sell & Migration                                      │
# └─────────────────────────────────────────────────────────────────────────────┘

LIVE_MIGRATE_SELL_PERCENT=1
LIVE_MIN_DEV_SELL_PERCENT=0.5
LIVE_DEV_SELL_PERCENT=0

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — PnL Order (TP/SL) Lifecycle                               │
# └─────────────────────────────────────────────────────────────────────────────┘

LIVE_PNL_ORDER_EXPIRE_DELTA_MS=43200000
LIVE_PNL_ORDER_EXPIRE_EXECUTE=true
LIVE_PNL_ORDER_USE_MID_PRICE=true
LIVE_SWAP_ORDER_POLL_MS=2000
LIVE_MAX_SWAP_ORDER_POLL_ATTEMPTS=30

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — WebSocket                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

LIVE_TRADE_WS_URL=wss://api-bot-v1.dbotx.com/trade/ws/

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — Safety & Circuit Breakers                                 │
# └─────────────────────────────────────────────────────────────────────────────┘

STOP_TRADING_PATH=./STOP_TRADING_LIVE
DUPLICATE_LOCK_WINDOW_MS=5000
MAX_CONSECUTIVE_API_FAILURES=5
MAX_WS_DISCONNECTS=5
MAX_TOTAL_SOL_DEPLOYED=0.5
MAX_PORTFOLIO_EXPOSURE_PCT=100
MAX_BUYS_PER_MINUTE=3
MAX_BUYS_PER_HOUR=20
# Duplicated in the Risk Controls section above; value there takes precedence.
#DAILY_LOSS_LIMIT_USD=20
RECONCILIATION_INTERVAL_MS=60000
WATCHDOG_INTERVAL_MS=15000
WATCHDOG_WS_STALE_MS=60000
WATCHDOG_BALANCE_STALE_MS=120000
WATCHDOG_PRICE_STALE_MS=60000
MAX_PRICE_DEVIATION_PCT=0

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Simulator Execution Defaults                                              │
# └─────────────────────────────────────────────────────────────────────────────┘

DEFAULT_SLIPPAGE=0.1
DEFAULT_GAS_FEE_DELTA=5
DEFAULT_MAX_FEE_PER_GAS=100

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Observability — Logging                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

LOG_LEVEL=info
