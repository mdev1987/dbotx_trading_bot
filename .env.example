# DBotX API credentials
DBOTX_API_KEY=
DBOTX_WS_URL=wss://api-data-v1.dbotx.com/data/ws/
DBOTX_BASE_URL=https://api-bot-v1.dbotx.com

# Account
POSITION_SIZE_SOL=0.10      # SOL per trade
MAX_POSITIONS=5

# Position TTL (seconds) — position auto-closes after this
TTL_POSITION_SECONDS=120     # 2 minutes
TTL_RENEWAL_PROFIT_PERCENT=3 # profit % threshold to reset TTL clock

# Signal queue — signals waiting when at max positions
SIGNAL_QUEUE_SIZE=20

# Partial take-profit tiers: PCT@PnL_PCT,PCT@PnL_PCT
#   "30@20,40@50" → sell 30% at +20%, 40% at +50%, rest rides trailing
PARTIAL_TP_TIERS=30@20,40@50

# Backstop TP (full remaining) — rarely hit with partial TPs
PAPER_BACKSTOP_TP_PERCENT=500

PAPER_STOP_LOSS_PERCENT=-15

# Trailing stop
PAPER_TRAILING_ACTIVATION_PERCENT=25  # gain % before trailing engages
PAPER_TRAILING_STOP_PERCENT=5         # how far from peak the trail sits

# Max loss per trade before panic exit (%)
PAPER_MAX_SLIPPAGE_EXIT_PERCENT=80

# Daily loss limit (USD) — stops accepting signals after this threshold
DAILY_LOSS_LIMIT_USD=0

# SQLite path for analytics
SQLITE_PATH=./data/paper_trading.sqlite

# Telegram bot (reporting)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_REPORT_INTERVAL_MINUTES=5    # report every 5 minutes

# Telegram client (signal source)
TELEGRAM_CHANNEL_ID=
TELEGRAM_CHANNEL_USERNAME=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Logging
LOG_LEVEL=info
