# ═══════════════════════════════════════════════════════════════════════════════
# DBotX Trade Bot — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values.  All settings have safe
# defaults so the bot can start with minimal configuration.
# ═══════════════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  DBotX API — Connection                                                    │
# │  Your DBotX credentials and API endpoints.                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

# API key for authenticating all requests to DBotX services.
# Required.  Obtain from your DBotX account dashboard.
DBOTX_API_KEY=

# WebSocket endpoint for real-time market data (pair updates, price ticks).
DBOTX_WS_URL=wss://api-data-v1.dbotx.com/data/ws/

# REST API base URL for simulator operations (orders, trades, account).
DBOTX_BASE_URL=https://api-bot-v1.dbotx.com

# Service API base URL for higher-level simulator queries (PnL tasks, trade pairs).
DBOTX_SERVAPI_BASE_URL=https://servapi.dbotx.com

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Position Sizing & Limits                                        │
# │  Controls how much capital each trade risks and how many concurrent trades. │
# └─────────────────────────────────────────────────────────────────────────────┘

# Base SOL amount allocated per position.
# The effective size is clamped by MIN_POSITION_SOL, MAX_POSITION_SOL, and
# MAX_RISK_PCT, so the actual amount may differ.
POSITION_SIZE_SOL=0.10

# Smallest position size allowed (in SOL).
# Prevents opening dust-sized trades that aren't worth the fees.
MIN_POSITION_SOL=0.03

# Largest position size allowed (in SOL).
# Hard cap to limit exposure on any single trade.
MAX_POSITION_SOL=0.10

# Maximum percentage of the total account balance that a single position may
# consume.  E.g. 1.0 means "at most 1 % of the balance".
MAX_RISK_PCT=1.0

# Maximum number of concurrently held (open) positions.
# Only effective in "ave" (Ave Scanner) mode.  In "monitor" mode no limit
# is applied.
MAX_POSITIONS=5

# Maximum number of signals that can wait in the queue when at MAX_POSITIONS.
# Oldest signals are dropped when the queue overflows.
SIGNAL_QUEUE_SIZE=20

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Position Time-To-Live (TTL)                                     │
# │  Controls how long a position lives before forced closure.                  │
# │  Only relevant for the Ave Scanner channel ("ave" mode).                   │
# └─────────────────────────────────────────────────────────────────────────────┘

# Base holding period (seconds) before the position is evaluated for expiry.
# If profit >= MIN_PROFIT_FOR_TTL_EXTENSION_PCT the clock resets; otherwise
# the position is closed.
BASE_TTL_SECS=90

# Minimum profit percentage required to extend the position TTL by another
# BASE_TTL_SECS window.  Set to 0 to disable TTL renewal entirely.
MIN_PROFIT_FOR_TTL_EXTENSION_PCT=3.0

# Absolute maximum lifetime (seconds) for any position, regardless of profit.
# The position is force-closed once this threshold is reached.
MAX_TTL_SECS=600

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Take-Profit / Stop-Loss                                         │
# │  Defines exit strategies for profitable and losing trades.                 │
# └─────────────────────────────────────────────────────────────────────────────┘

# Enable partial take-profit scaling (multiple sell orders at different profit
# levels).  When disabled (default), the entire position is closed in a single
# transaction by either the backstop TP, stop-loss, or trailing mechanisms.
PARTIAL_TP_ENABLED=false

# Partial take-profit tiers in the format "PCT@PnL_PCT,PCT@PnL_PCT".
# Example: "20@30,30@50" sells 20 % at +30 % profit and 30 % at +50 % profit,
# leaving 50 % of the position for the trailing mechanisms or backstop TP.
# When using the AveSignalMonitor channel, TP is derived from the signal's
# maxPumpX field instead of this config.
# Only effective when PARTIAL_TP_ENABLED=true.
PARTIAL_TP_TIERS=20@30,30@50

# Backstop take-profit percentage for the remaining position.
# When PARTIAL_TP_ENABLED=true, this covers whatever fraction of the position
# was not allocated by the partial tiers.  When PARTIAL_TP_ENABLED=false,
# this becomes the single take-profit target for the full position.
# E.g. 200 means "sell the full position at +200 %".
PAPER_BACKSTOP_TP_PERCENT=200

# Stop-loss threshold as a signed percentage below entry price.
# E.g. -15 triggers a market sell when the price falls 15 % below entry.
# Set to 0 or leave empty to disable stop-loss.
PAPER_STOP_LOSS_PERCENT=-15

# Gain percentage from entry price required before the trailing stop activates.
# E.g. 15 means "trailing stop starts after price rises 15 % above entry".
# Set to 0 for immediate activation.
PAPER_TRAILING_ACTIVATION_PERCENT=15

# How far (as a percentage) the trailing stop sits below the peak price.
# E.g. 8 means "sell if price drops 8 % from the all-time high".
# Set to 0 or leave empty to disable trailing stop-loss.
PAPER_TRAILING_STOP_PERCENT=8

# Trailing take-profit distance below the peak price.
# Unlike the trailing stop, this is always active from entry (no activation
# threshold).  Automatically locks in profit when the price reverses.
# E.g. 12 means "take profit when price drops 12 % from the peak".
# Set to 0 or leave empty to disable trailing TP.
PAPER_TRAILING_TP_PERCENT=12

# Maximum allowed exit slippage as a percentage.  If actual exit deviates more
# than this from the expected price the order is treated as a panic exit.
PAPER_MAX_SLIPPAGE_EXIT_PERCENT=80

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Risk Controls                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

# Daily loss limit in USD.  When the day's realised PnL crosses below this
# negative threshold no new positions are opened.  Set to 0 to disable.
DAILY_LOSS_LIMIT_USD=0

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Data & Analytics                                                          │
# └─────────────────────────────────────────────────────────────────────────────┘

# Filesystem path to the SQLite database file used for persisting trade
# history and position events.  The directory is created automatically.
SQLITE_PATH=./data/paper_trading.sqlite

# Set to "true" to drop all position and task tables on startup, giving the
# bot a completely fresh analytics slate.  Use with caution — data is not
# recoverable after deletion.
CLEAR_ANALYTICS_ON_START=false

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Bot Reporting                                                  │
# │  Optional.  When configured, the bot sends real-time notifications and     │
# │  periodic performance reports to a Telegram chat.                          │
# └─────────────────────────────────────────────────────────────────────────────┘

# Bot token from @BotFather.  Required only if you want Telegram reporting.
TELEGRAM_BOT_TOKEN=

# Target chat (or channel) ID where reports are delivered.
TELEGRAM_CHAT_ID=

# Interval (minutes) between automatic performance summary reports.
TELEGRAM_REPORT_INTERVAL_MINUTES=5

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Signal Listener                                                │
# │  Credentials for the MTProto client that reads trading signals from a      │
# │  Telegram channel.                                                         │
# └─────────────────────────────────────────────────────────────────────────────┘

# Your Telegram API ID from my.telegram.org/apps.
TELEGRAM_API_ID=

# Your Telegram API hash from my.telegram.org/apps.
TELEGRAM_API_HASH=

# Telegram channel username to read signals from (without the leading @).
# Two parsers are auto-detected from the channel name:
#   AveSignalMonitor     → "monitor" mode (no position limit, pump TP, no TTL)
#   AveSolanaTokenScanner → "ave" mode (max positions, TTL expiry, config TP)
TELEGRAM_CHANNEL_USERNAME=AveSignalMonitor

# Numeric channel ID (alternative to username).  Only one of
# CHANNEL_USERNAME or CHANNEL_ID needs to be set.
TELEGRAM_CHANNEL_ID=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Polling & Timing — Position Lifecycle                                     │
# │  Intervals controlling how often background tasks poll or check state.     │
# └─────────────────────────────────────────────────────────────────────────────┘

# Interval (ms) between TP/SL task state polls for open positions.
PNL_TASK_POLL_MS=5000

# Interval (ms) between trade-pair balance / live PnL polls.
TRADE_PAIR_POLL_MS=30000

# Delay (ms) between retry attempts when fetching the entry price after a buy.
ENTRY_PRICE_POLL_DELAY_MS=1000

# Maximum number of retry attempts when fetching the entry price.
MAX_ENTRY_PRICE_ATTEMPTS=10

# TTL (ms) for the pending-buy dedup guard — prevents double-buying when a
# request times out but the server already created the order.
PENDING_BUY_TTL_MS=60000

# Interval (ms) at which open positions are checked for TTL expiry / renewal.
POSITION_EXPIRY_CHECK_MS=15000

# Interval (ms) at which the simulator account balance is auto-refreshed.
ACCOUNT_POLL_INTERVAL_MS=60000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  WebSocket — Connection & Heartbeat                                        │
# └─────────────────────────────────────────────────────────────────────────────┘

# Heartbeat / ping interval (ms) to keep the WebSocket alive.
WS_HEARTBEAT_INTERVAL_MS=30000

# Throttle interval (ms) for repeated WebSocket disconnect log messages.
WS_DISCONNECT_LOG_THROTTLE_MS=30000

# Delay (ms) before attempting reconnection after a WebSocket disconnect.
WS_RECONNECT_DELAY_MS=5000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Signal Deduplication                                                      │
# │  Controls how long signals are remembered to suppress duplicates.          │
# └─────────────────────────────────────────────────────────────────────────────┘

# TTL (seconds) for the signal dedup cache — a signal is ignored if the same
# LP address was seen within this window.
SIGNAL_CACHE_TTL_SECONDS=3600

# Interval (ms) for the signal cache cleanup tick (evicts stale entries).
SIGNAL_CLEANUP_INTERVAL_MS=5000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  HTTP Client — Retry & Timeout                                             │
# └─────────────────────────────────────────────────────────────────────────────┘

# Maximum number of HTTP request retry attempts.
HTTP_MAX_RETRIES=4

# Base delay (ms) for exponential backoff between retries.
HTTP_BASE_DELAY_MS=1000

# HTTP request timeout (ms).
HTTP_TIMEOUT_MS=30000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram Connection — MTProto Client                                      │
# └─────────────────────────────────────────────────────────────────────────────┘

# Maximum connection retry attempts for the Telegram MTProto client.
TG_CONNECTION_RETRIES=5

# Delay (ms) between Telegram connection retry attempts.
TG_RETRY_DELAY_MS=5000

# Timeout (ms) for Telegram CLI authentication input prompt.
TG_AUTH_TIMEOUT_MS=300000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Simulator Execution Defaults                                              │
# │  Default parameters used when placing simulator swap orders.               │
# └─────────────────────────────────────────────────────────────────────────────┘

# Default slippage fraction for simulator orders (e.g. 0.1 = 10 %).
DEFAULT_SLIPPAGE=0.1

# Default gas fee delta for simulator swap orders.
DEFAULT_GAS_FEE_DELTA=5

# Default max fee per gas for simulator swap orders.
DEFAULT_MAX_FEE_PER_GAS=100

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Observability — Logging                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

# Log verbosity level.  One of: "debug", "info", "warn", "error".
LOG_LEVEL=info
