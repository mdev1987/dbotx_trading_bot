# ═══════════════════════════════════════════════════════════════════════════════
# DBotX Trade Bot — Example Environment
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Sections are kept in alphabetical order for easy navigation.
# ═══════════════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  DBotX API — Connection                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

DBOTX_API_KEY=your_dbotx_api_key                            # API key for authenticating with DBotX services
DBOTX_WS_URL=wss://api-data-v1.dbotx.com/data/ws/            # WebSocket URL for real-time price data feed
DBOTX_BASE_URL=https://api-bot-v1.dbotx.com                  # REST API base URL for bot trading operations
DBOTX_DATA_BASE_URL=https://api-data-v1.dbotx.com             # REST API base URL for data queries (pair info etc.)
DBOTX_SERVAPI_BASE_URL=https://servapi.dbotx.com              # Service API base URL for simulator operations

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  HTTP Client — Retry & Timeout                                             │
# └─────────────────────────────────────────────────────────────────────────────┘

HTTP_MAX_RETRIES=4                                           # Maximum number of retry attempts for failed HTTP requests
HTTP_BASE_DELAY_MS=1000                                      # Base delay in ms for exponential backoff between retries
HTTP_TIMEOUT_MS=30000                                        # HTTP request timeout in milliseconds

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — Dev Sell & Migration                                      │
# └─────────────────────────────────────────────────────────────────────────────┘

LIVE_MIGRATE_SELL_PERCENT=1                                  # Ratio to sell when token migrates from pump to Raydium (1 = 100%)
LIVE_MIN_DEV_SELL_PERCENT=0.5                                # Dev sell threshold that triggers sell-ratio activation
LIVE_DEV_SELL_PERCENT=0                                      # Amount dev wallets sell (0 = disabled, 1 = 100%)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — Jito / Anti-MEV                                           │
# └─────────────────────────────────────────────────────────────────────────────┘

LIVE_JITO_ENABLED=true                                       # Enable Jito anti-MEV protection for swap orders
LIVE_JITO_TIP=0.0001                                         # Jito bribery tip amount in SOL
LIVE_CUSTOM_FEE_AND_TIP=false                                # Override priority fee and tip manually when true
LIVE_PRIORITY_FEE=                                           # Custom priority fee (auto-calculated when empty)
LIVE_MAX_SLIPPAGE=0.1                                        # Maximum allowed slippage (0.00-1.00 = 0%-100%)
LIVE_CONCURRENT_NODES=2                                      # Number of parallel validation nodes (1-3)
LIVE_RETRIES=1                                               # Swap order retry count on failure (0-10)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — Exit PnL Custom Config (separate fee/slippage for TP/SL)   │
# └─────────────────────────────────────────────────────────────────────────────┘

LIVE_EXIT_CUSTOM_FEE_AND_TIP=false                            # Override priority fee and tip for exit tasks
LIVE_EXIT_PRIORITY_FEE=                                       # Custom priority fee for exit tasks (auto when empty)
LIVE_EXIT_JITO_ENABLED=true                                   # Enable Jito for exit TP/SL tasks
LIVE_EXIT_JITO_TIP=0.0001                                     # Jito tip for exit tasks in SOL
LIVE_EXIT_MAX_SLIPPAGE=0.3                                    # Max slippage for exit tasks (0.00-1.00)
LIVE_EXIT_CONCURRENT_NODES=2                                  # Parallel validation nodes for exit tasks (1-3)
LIVE_EXIT_RETRIES=2                                           # Swap retry count for exit tasks (0-10)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — Mode & Wallet                                              │
# └─────────────────────────────────────────────────────────────────────────────┘

LIVE_MODE=false                                              # Master switch: true = live trading, false = simulator
LIVE_BUY_ENABLED=true                                        # Allow new buy orders (set false to close-only)
LIVE_WALLET_ID=your_dbotx_wallet_id                          # Wallet ID from DBotX Wallet Info page
LIVE_WALLET_ADDRESS=your_wallet_public_address                # On-chain wallet public key address
LIVE_RECOVERY_ON_START=true                                  # Scan and recover open orders on bot startup
LIVE_DB_PATH=./data/live_trading.sqlite                      # Path to SQLite database for live trading state

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — PnL Order (TP/SL) Lifecycle                               │
# └─────────────────────────────────────────────────────────────────────────────┘

LIVE_PNL_ORDER_EXPIRE_DELTA_MS=43200000                      # TP/SL order task expiry in ms (max 5 days = 43200000)
LIVE_PNL_ORDER_EXPIRE_EXECUTE=true                           # Execute market sell when PnL order expires
LIVE_PNL_ORDER_USE_MID_PRICE=true                            # Use mid-price instead of last-trade for PnL calculations
LIVE_PNL_ORDER_EXPIRE_EXECUTE_SELL_ALL=false                 # Sell entire position vs remaining on PnL order expire
LIVE_PNL_CUSTOM_CONFIG_ENABLED=true                          # Use separate fee/slippage for TP/SL exit tasks
LIVE_SWAP_ORDER_POLL_MS=2000                                 # Interval in ms for polling swap order status after submission
LIVE_MAX_SWAP_ORDER_POLL_ATTEMPTS=30                         # Maximum number of swap order status poll attempts

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — Safety & Circuit Breakers                                 │
# └─────────────────────────────────────────────────────────────────────────────┘

STOP_TRADING_PATH=./STOP_TRADING_LIVE                        # File path; if this file exists all trading stops immediately
DUPLICATE_LOCK_WINDOW_MS=5000                                # Time window in ms to prevent duplicate buy orders for same pair
MAX_CONSECUTIVE_API_FAILURES=5                               # Max consecutive API failures before circuit breaker triggers
MAX_WS_DISCONNECTS=5                                         # Max WebSocket disconnections before circuit breaker triggers
MAX_TOTAL_SOL_DEPLOYED=0.5                                   # Maximum total SOL that can be deployed across all positions
MAX_PORTFOLIO_EXPOSURE_PCT=100                               # Max percentage of wallet balance exposed in open positions
MAX_BUYS_PER_MINUTE=3                                        # Rate limit: max buy orders per minute
MAX_BUYS_PER_HOUR=20                                         # Rate limit: max buy orders per hour
DAILY_LOSS_LIMIT_USD=20                                      # Daily realised PnL loss limit in USD (0 = disabled)
RECONCILIATION_INTERVAL_MS=60000                             # Interval in ms for reconciling on-chain vs local position state
WATCHDOG_INTERVAL_MS=15000                                   # Interval in ms for watchdog health checks
WATCHDOG_WS_STALE_MS=60000                                   # Milliseconds after which WebSocket is considered stale
WATCHDOG_BALANCE_STALE_MS=120000                             # Milliseconds after which wallet balance is considered stale
WATCHDOG_PRICE_STALE_MS=60000                                # Milliseconds after which price data is considered stale
MAX_PRICE_DEVIATION_PCT=0                                    # Max allowed price deviation before rejecting trade (0 = disabled)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Live Trading — WebSocket                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

LIVE_TRADE_WS_URL=wss://api-bot-v1.dbotx.com/trade/ws/      # WebSocket URL for live trade result events

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Price Data Streams                                                        │
# └─────────────────────────────────────────────────────────────────────────────┘

PUMPAPI_WS_URL=wss://stream.pumpapi.io/                     # WebSocket URL for PumpAPI real-time token data
DEXSCREENER_API_URL=https://api.dexscreener.com/tokens/v1/solana  # DexScreener REST API base URL
DEXSCREENER_POLL_INTERVAL_MS=30000                           # Polling interval in ms for DexScreener price lookups

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Observability — Logging                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

LOG_LEVEL=info                                               # Log verbosity: debug | info | warn | error

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Polling & Timing — Position Lifecycle                                     │
# └─────────────────────────────────────────────────────────────────────────────┘

PNL_TASK_POLL_MS=5000                                        # Interval in ms for polling TP/SL task status
TRADE_PAIR_POLL_MS=30000                                     # Interval in ms for polling trade pair PnL data
ENTRY_PRICE_POLL_DELAY_MS=1000                               # Delay in ms between entry price capture retry attempts
MAX_ENTRY_PRICE_ATTEMPTS=10                                  # Maximum entry price capture retries before fallback
PENDING_BUY_TTL_MS=60000                                     # Time-to-live in ms for pending buy deduplication guard
POSITION_EXPIRY_CHECK_MS=15000                               # Interval in ms for checking position TTL expiry
ACCOUNT_POLL_INTERVAL_MS=60000                               # Interval in ms for polling account balance

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Signal Deduplication                                                      │
# └─────────────────────────────────────────────────────────────────────────────┘

SIGNAL_CACHE_TTL_SECONDS=3600                                # Time-to-live in seconds for signal dedup cache entries
SIGNAL_CLEANUP_INTERVAL_MS=5000                              # Interval in ms for expired signal cache cleanup

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Simulator Execution Defaults                                              │
# └─────────────────────────────────────────────────────────────────────────────┘

DEFAULT_SLIPPAGE=0.1                                         # Default slippage tolerance for simulator trades (10%)
DEFAULT_GAS_FEE_DELTA=5                                      # Default gas fee delta for simulator transactions
DEFAULT_MAX_FEE_PER_GAS=100                                  # Default maximum fee per gas unit for simulator
SIMULATOR_TASK_TIMEOUT_SECS=30                               # Maximum seconds to wait for simulator buy/sell task completion
SIMULATOR_TASK_POLL_INTERVAL_MS=500                          # Polling interval in ms for simulator task status checks

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Bot Reporting                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

TELEGRAM_BOT_TOKEN=your_telegram_bot_token                    # GrammY bot token for sending trade reports to Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id                        # Telegram chat ID where reports are delivered
TELEGRAM_REPORT_INTERVAL_MINUTES=5                            # Interval in minutes between periodic performance reports

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Connection (MTProto Client)                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

TG_CONNECTION_RETRIES=5                                      # Number of MTProto connection retry attempts on failure
TG_RETRY_DELAY_MS=5000                                       # Delay in ms between MTProto connection retry attempts
TG_AUTH_TIMEOUT_MS=300000                                    # Timeout in ms for Telegram authentication input (5 min)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Telegram — Signal Listener (Ave Solana Token Scanner)                     │
# └─────────────────────────────────────────────────────────────────────────────┘

TELEGRAM_API_ID=your_telegram_api_id                          # MTProto API ID from my.telegram.org
TELEGRAM_API_HASH=your_telegram_api_hash                      # MTProto API hash from my.telegram.org
TELEGRAM_CHANNEL_USERNAME=AveSolanaTokenScanner               # Telegram channel username (only scanner channel supported)
TELEGRAM_CHANNEL_ID=your_telegram_channel_id                  # Numeric Telegram channel ID (optional, alternative to username)
TELEGRAM_SOLTRENDING_CHANNEL_ID=2135710857                    # @SOLTRENDING channel numeric ID (sets source to SOLTRENDING when provided)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Position Sizing & Limits                                        │
# └─────────────────────────────────────────────────────────────────────────────┘

POSITION_SIZE_SOL=0.10                                       # Default position size in SOL for each trade
MIN_POSITION_SOL=0.03                                        # Minimum allowed position size in SOL
MAX_POSITION_SOL=0.10                                        # Maximum allowed position size in SOL
MAX_RISK_PCT=10.0                                            # Max percentage of wallet balance risked per trade
MAX_POSITIONS=5                                              # Maximum number of concurrent open positions
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Position TTL                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

BASE_TTL_SECS=90                                             # Initial position holding time before TTL expiry evaluation
MIN_PROFIT_FOR_TTL_EXTENSION_PCT=8.0                         # Profit percentage needed to reset TTL timer (0 = disabled)
MAX_TTL_SECS=600                                             # Hard cap on position lifetime in seconds

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Trading — Take-Profit / Stop-Loss                                         │
# └─────────────────────────────────────────────────────────────────────────────┘

PARTIAL_TP_ENABLED=true                                      # Enable partial take-profit tier execution
PARTIAL_TP_TIERS=25@30,25@60,25@100                          # Partial TP: "pct%@at%" comma-separated (sell 25% at +30%, etc.)
BACKSTOP_TP_PERCENT=200                                      # Backstop TP for remainder position (0 = disabled)
STOP_LOSS_ENABLED=false                                      # Enable stop loss (true/false)
STOP_LOSS_PERCENT=-15                                        # Stop loss threshold as negative percentage (0 = disabled)
TRAILING_ACTIVATION_PERCENT=15                               # Gain percentage before trailing stop activates (0 = disabled)
TRAILING_STOP_PERCENT=8                                      # Trail distance percentage below peak price (0 = disabled)
STOP_LOSS_TIERS=                                             # Graduated stop loss: "50@-20,100@-50" (pct%@at% comma-separated)

MAX_SLIPPAGE_EXIT_PERCENT=80                                 # Maximum allowed slippage percentage on exit trades

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  WebSocket — Connection & Heartbeat                                        │
# └─────────────────────────────────────────────────────────────────────────────┘

WS_HEARTBEAT_INTERVAL_MS=30000                               # Interval in ms for WebSocket ping heartbeat
WS_DISCONNECT_LOG_THROTTLE_MS=30000                           # Throttle interval in ms for repeated disconnect log messages
WS_RECONNECT_DELAY_MS=5000                                   # Delay in ms before attempting WebSocket reconnection
