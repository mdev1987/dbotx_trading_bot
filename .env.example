# DBotX API credentials
DBOTX_API_KEY=
DBOTX_WS_URL=wss://api-data-v1.dbotx.com/data/ws/
DBOTX_BASE_URL=https://api-bot-v1.dbotx.com

# Account
POSITION_SIZE_SOL=0.10      # SOL per trade (base, clamped by min/max)
MIN_POSITION_SOL=0.03       # smallest position allowed (SOL)
MAX_POSITION_SOL=0.10       # largest position allowed (SOL)
MAX_RISK_PCT=1.0            # max % of account balance risked on a single trade
MAX_POSITIONS=5

# Signal source mode
#   'monitor' — Ave Signal Monitor (no TTL, no max pos, accept all, pump TP)
#   'ave'     — AVE Scanner (TTL, max positions, queue, config TP)
SIGNAL_SOURCE_MODE=monitor

# Position TTL (seconds) — only used in 'ave' mode
BASE_TTL_SECS=90                 # initial holding time before evaluation
MIN_PROFIT_FOR_TTL_EXTENSION_PCT=3.0  # profit% required to reset TTL clock
MAX_TTL_SECS=600                 # hard absolute cap on position lifetime

# Signal queue — only used in 'ave' mode
SIGNAL_QUEUE_SIZE=20

# Partial take-profit tiers: PCT@PnL_PCT,PCT@PnL_PCT
#   "30@20,40@50" → sell 30% at +20%, 40% at +50%, rest rides trailing
#   In 'monitor' mode TP is derived from signal's maxPumpX instead.
PARTIAL_TP_TIERS=30@20,40@50

# Backstop TP (full remaining) — rarely hit with partial TPs
PAPER_BACKSTOP_TP_PERCENT=500

PAPER_STOP_LOSS_PERCENT=-15

# Trailing stop
PAPER_TRAILING_ACTIVATION_PERCENT=25  # gain % before trailing engages
PAPER_TRAILING_STOP_PERCENT=5         # how far from peak the trail sits

# Max loss per trade before panic exit (%)
PAPER_MAX_SLIPPAGE_EXIT_PERCENT=80

# Daily loss limit (USD) — stops accepting signals after this threshold
DAILY_LOSS_LIMIT_USD=0

# SQLite path for analytics
SQLITE_PATH=./data/paper_trading.sqlite

# Telegram bot (reporting)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_REPORT_INTERVAL_MINUTES=5    # report every 5 minutes

# Telegram client (single channel — set to @AveSignalMonitor or @Ave_Scanner_Bot)
TELEGRAM_CHANNEL_ID=
TELEGRAM_CHANNEL_USERNAME=@AveSignalMonitor
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Logging
LOG_LEVEL=info
