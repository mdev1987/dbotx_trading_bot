{
  "name": "dbotx_trade_ts",
  "module": "src/entry.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/entry.ts",
    "dev": "LOG_LEVEL=DEBUG bun run ./src/entry.ts",
    "encrypt": "bun run src/crypto/cli_encrypt.ts",
