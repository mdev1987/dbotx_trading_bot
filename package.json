  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "@inquirer/prompts": "^8.5.2",
    "@notifycode/hash-it": "^1.0.0",
    "grammy": "^1.44.0",
    "remove-markdown": "^0.6.4",
    "rxjs": "^7.8.2",
    "telegram-markdown-v2": "^0.0.5",
    "teleproto": "^1.227.1"
  }
}
